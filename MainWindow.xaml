<ui:FluentWindow x:Class="UnturnedModManager.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                xmlns:pages="clr-namespace:UnturnedModManager.Pages"
                mc:Ignorable="d"
                Title="Unturned Mod Manager"
                Height="720" Width="1100"
                MinHeight="520" MinWidth="900"
                WindowBackdropType="Mica"
                WindowCornerPreference="Round"
                ExtendsContentIntoTitleBar="True"
                WindowStartupLocation="CenterScreen">

    <Grid x:Name="RootGrid">
        <ui:NavigationView x:Name="NavigationView"
                           Margin="0,40,0,0"
                           Padding="42,0,42,0"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           OpenPaneLength="220">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="游戏启动"
                                       Icon="{ui:SymbolIcon Home24}"
                                       TargetPageType="{x:Type pages:HomePage}" />
                <ui:NavigationViewItem Content="模组管理"
                                       Icon="{ui:SymbolIcon Box24}"
                                       TargetPageType="{x:Type pages:ModListPage}" />
                <ui:NavigationViewItem Content="设置"
                                       Icon="{ui:SymbolIcon Settings24}"
                                       TargetPageType="{x:Type pages:SettingsPage}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="关于"
                                       Icon="{ui:SymbolIcon Info24}"
                                       TargetPageType="{x:Type pages:AboutPage}" />
            </ui:NavigationView.FooterMenuItems>

            <ui:NavigationView.PaneFooter>
                <ui:Button x:Name="ThemeToggleButton"
                           Margin="12,4,12,12"
                           HorizontalAlignment="Stretch"
                           Appearance="Secondary"
                           Click="ThemeToggleButton_Click"
                           ToolTip="切换深色/浅色主题">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ui:SymbolIcon x:Name="ThemeToggleButtonIcon"
                                       Symbol="WeatherMoon24"
                                       FontSize="16"
                                       Margin="0,0,8,0" />
                        <TextBlock x:Name="ThemeToggleText"
                                   Text="深色模式"
                                   VerticalAlignment="Center"
                                   FontSize="13" />
                    </StackPanel>
                </ui:Button>
            </ui:NavigationView.PaneFooter>
        </ui:NavigationView>

        <ui:TitleBar x:Name="TitleBar"
                     Title="Unturned Mod Manager"
                     Grid.Row="0"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True" />

    </Grid>
</ui:FluentWindow>