<Page x:Class="UnturnedModManager.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="设置"
      Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Margin="0,8,0,24">
            <TextBlock Text="设置"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="配置游戏路径与应用行为"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- 设置项目 -->
        <StackPanel Grid.Row="1" MaxWidth="600"
                    PreviewMouseWheel="CardPanel_PreviewMouseWheel">

            <!-- 顶部状态反馈条 -->
            <ui:InfoBar x:Name="StatusInfoBar"
                        IsOpen="False"
                        Title=""
                        Message=""
                        Margin="0,0,0,20" />

            <!-- 游戏安装路径 -->
            <Border CornerRadius="8"
                    Padding="20,16"
                    Margin="0,0,0,20"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <TextBlock Text="Unturned 安装路径"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="指向游戏根目录（包含 Unturned.exe 的文件夹）"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,2,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="GamePathTextBox"
                                    Grid.Column="0"
                                    PlaceholderText="例如: C:\Program Files (x86)\Steam\steamapps\common\Unturned" />
                        <ui:Button Grid.Column="1"
                                   Content="浏览..."
                                   Appearance="Secondary"
                                   Margin="12,0,0,0"
                                   Click="BrowsePathButton_Click" />
                        <ui:Button x:Name="AutoDetectButton"
                                   Grid.Column="2"
                                   Content="自动寻找"
                                   Icon="{ui:SymbolIcon Search16}"
                                   Appearance="Secondary"
                                   Margin="5,0,0,0"
                                   Click="AutoDetectButton_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 保存按钮 -->
            <ui:Button x:Name="SaveButton"
                       Appearance="Primary"
                       Content="保存设置"
                       Icon="{ui:SymbolIcon Save24}"
                       HorizontalAlignment="Left"
                       Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Page>