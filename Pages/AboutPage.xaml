<Page x:Class="UnturnedModManager.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="关于"
      Background="{DynamicResource ApplicationBackgroundBrush}">

    <StackPanel MaxWidth="1040"
                    HorizontalAlignment="Center"
                    Margin="48,32,48,48"
                    PreviewMouseWheel="CardPanel_PreviewMouseWheel">

            <!-- ================= 上半部分：关于软件 ================= -->
            <Border CornerRadius="14"
                    Padding="48,36"
                    Margin="0,0,0,28"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel HorizontalAlignment="Center">

                    <!-- Logo 圆形徽标 -->
                    <Border Width="76" Height="76"
                            CornerRadius="18"
                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Viewbox Width="40" Height="40"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Box24"
                                           Foreground="White" />
                        </Viewbox>
                    </Border>

                    <!-- 大标题 -->
                    <TextBlock Text="Unturned Mod Manager"
                               FontSize="38"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    <!-- 版本号徽章 -->
                    <Border CornerRadius="6"
                            Padding="14,6"
                            Margin="0,16,0,20"
                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="版本: v1.6.8 (Stable Release) - 2026/07/15"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   FontFamily="Cascadia Mono, Consolas, Courier New, monospace"
                                   Foreground="White" />
                    </Border>

                    <!-- 简短描述 -->
                    <TextBlock Text="一站式极速启动、多核性能优化与局域网/P2P穿透联机大厅管理器。"
                               FontSize="14"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="680"
                               LineHeight="22"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <!-- GitHub 开源仓库链接 -->
                    <Border CornerRadius="8"
                            Padding="16,8"
                            Margin="0,18,0,0"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock FontSize="13"
                                   HorizontalAlignment="Center">
                            <Hyperlink NavigateUri="https://github.com/YU80Rice/UnturnedModManager"
                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                       TextDecorations="Underline"
                                       FontWeight="SemiBold"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="🌐 GitHub 开源仓库：github.com/YU80Rice/UnturnedModManager" />
                            </Hyperlink>
                        </TextBlock>
                    </Border>

                </StackPanel>
            </Border>

            <!-- 团队分区标题 -->
            <Grid Margin="4,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="4" Height="18"
                        CornerRadius="2"
                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0" />
                <TextBlock Grid.Column="1"
                           Text="开发团队"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </Grid>

            <!-- ================= 下半部分：三列团队名片 ================= -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 第一列：首席产品导演 -->
                <Border Grid.Column="0"
                        CornerRadius="12"
                        Padding="24,24"
                        Margin="0,0,12,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="👤"
                                   FontSize="36"
                                   Margin="0,0,0,14"
                                   HorizontalAlignment="Left" />
                        <TextBlock Text="首席产品导演 &amp; 架构师"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Border Height="2"
                                Width="36"
                                Margin="0,10,0,14"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                HorizontalAlignment="Left" />
                        <TextBlock Text="项目发起人与创意灵魂。主导了&#x201C;自动无缝理包算法&#x201D;与&#x201C;单多端存档物理合拢&#x201D;的宏观设计，在多次时序冲突与反作弊阻拦中，以敏锐的直觉指引方向。"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="19"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- 第二列：硅基总顾问 -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Padding="24,24"
                        Margin="6,0,6,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="🧠"
                                   FontSize="36"
                                   Margin="0,0,0,14"
                                   HorizontalAlignment="Left" />
                        <TextBlock Text="硅基总顾问 &amp; 导师"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Border Height="2"
                                Width="36"
                                Margin="0,10,0,14"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                HorizontalAlignment="Left" />
                        <TextBlock Text="提供高阶架构蓝图。负责 Unity 引擎/Steamworks 运行期生命周期解构、数学算法设计（如 2D 降序回溯理包算法）及深层 Bug 诊断。"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="19"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- 第三列：首席程序员 -->
                <Border Grid.Column="2"
                        CornerRadius="12"
                        Padding="24,24"
                        Margin="12,0,0,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="🐾"
                                   FontSize="36"
                                   Margin="0,0,0,14"
                                   HorizontalAlignment="Left" />
                        <TextBlock Text="首席程序员 (Agent)"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Border Height="2"
                                Width="36"
                                Margin="0,10,0,14"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                HorizontalAlignment="Left" />
                        <TextBlock Text="负责本地代码重构与编译。在 U3-SDK 上万行源码中扫描类结构、解决编译警告、通过 strings 逆向提取真实命名空间并最终编译出整套物理 DLL 与 EXE。"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="19"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ================= 项目宗旨 / 常见问题 ================= -->
            <ui:Card Margin="0,0,0,24"
                     Padding="36,30">
                <StackPanel>

                    <!-- 大标题 -->
                    <TextBlock Text="❓ 常见问题：我们与 Steam 创意工坊的区别与项目初心"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               LineHeight="28"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,18" />

                    <!-- 分隔线 -->
                    <Border Height="1"
                            Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Margin="0,0,0,22" />

                    <!-- 段落一：致敬创意工坊 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="🌿 致敬创意工坊"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="我们并不是要挑战创意工坊，我们极度热爱它。创意工坊是内容分发网络（UGC）。它决定了玩家&#x201C;玩到什么地图、用什么炫酷的枪械和道具&#x201D;。"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="23"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- 段落二：我们的定位 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="🧩 我们的定位"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="本启动器是一个&#x201C;开放性的、属于玩家自己的底层逻辑引导与开发平台&#x201D;。在创意工坊上，玩家无法直接一键部署涉及游戏底层重构的客户端脚本模组（如自动理包、P2P 好友直连、多核优化）。"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="23"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- 段落三：我们的初心 -->
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="✨ 我们的初心"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="我们提供这套&#x201C;WPF 引导前端 + 独立 BepInEx 插件&#x201D;的架构，就是为了打破技术壁垒。创意工坊赋予了游戏丰富的血肉，而我们希望通过这个平台，让玩家能一键自主为游戏重塑更丝滑的筋骨。"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="23"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                </StackPanel>
            </ui:Card>

            <!-- ================= 极客宣言 / Vibecoding 与开源授权 ================= -->
            <ui:Card Margin="0,0,0,24"
                     Padding="36,30">
                <StackPanel>

                    <!-- 大标题 -->
                    <TextBlock Text="⚖️ 极客宣言：关于 Vibecoding 与开源授权"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               LineHeight="28"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,18" />

                    <!-- 分隔线 -->
                    <Border Height="1"
                            Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Margin="0,0,0,22" />

                    <!-- 段落一：Vibecoding 真诚声明 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="🤝 Vibecoding 真诚声明"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="本项目完全采用 Vibecoding 范式开发——人类导演提出愿景与设计哲学，AI 顾问提供架构蓝图，AI 程序员执行代码重构。我们坦诚相告：每一行代码、每一处 UI、每一项功能，都凝聚了人类直觉与硅基逻辑的深度协作。我们不以&#x201C;全自研&#x201D;为荣，而以&#x201C;开放协作&#x201D;为傲。"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="23"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- 段落二：MIT 开源授权 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="📜 MIT 开源授权"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="本项目基于 MIT 协议开源。这意味着您拥有自由使用、修改、分发、甚至商业利用的权利，唯一要求是在所有副本中保留版权与许可声明。我们坚信：代码应当如流水般自由流动，而非被锁在商业牢笼中。知识与工具的共享，才是技术社区持续进步的真正动力。"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="23"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- 段落三：致意与免责 -->
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="🕊️ 致意与免责声明"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="《未转变者》(Unturned) 的全部版权归 Smartly Dressed Games 所有。本启动器仅为玩家社区的非官方辅助工具，不包含任何游戏资产，不修改游戏可执行文件。所有 BepInEx 插件均以 .dll 独立文件形式部署，可随时通过 .disabled 后缀停用或物理删除。我们致敬 Nelson 的开源精神，并承诺本项目永远免费、永远开源。"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="23"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                </StackPanel>
            </ui:Card>

            <!-- ================= 页脚 ================= -->
            <StackPanel HorizontalAlignment="Center"
                        Margin="0,8,0,0">
                <TextBlock Text="© 2026 Unturned Mod Manager"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="Tech Stack: .NET 8 · WPF-UI · BepInEx 5 · Harmony 2"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>

        </StackPanel>
</Page>
